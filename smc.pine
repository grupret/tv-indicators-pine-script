alertcondition(bullSweep,    "Bullish Liquidity Sweep",  "Bull sweep: wick pierced swing low, closed above")
alertcondition(bearSweep,    "Bearish Liquidity Sweep",  "Bear sweep: wick pierced swing high, closed below")
alertcondition(bullObTouched,"Bullish OB Touch",         "Price entered bullish order block zone")
alertcondition(bearObTouched,"Bearish OB Touch",         "Price entered bearish order block zone")
alertcondition(bearBOS,      "Bearish BOS",              "Bearish break of structure: close < swing low")
alertcondition(chochSig,     "CHoCH",                    "Change of character: lower high confirmed")
alertcondition(instBuy,      "Institutional Buy",        "High-vol bullish OB impulse detected")
alertcondition(instSell,     "Institutional Sell",       "High-vol bearish OB impulse detected")
alertcondition(buySignal,    "EMA/VWAP Buy Signal",      "EMA 9/20 cross + VWAP filter Buy")
alertcondition(sellSignal,   "EMA/VWAP Sell Signal",     "EMA 9/20 cross + VWAP filter Sell")

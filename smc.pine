//@version=6
indicator("SMC Overlay [Intraday]", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=200)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════════
i_obLookback = input.int(10,   "OB Lookback",              minval=1,        group="Order Blocks")
i_obMax      = input.int(5,    "OB Max Display",           minval=1, maxval=20, group="Order Blocks")
i_swingLB    = input.int(10,   "Swing Lookback",           minval=2,        group="Structure")

// --- Supply & Demand (S&D) ---
i_showSD     = input.bool(true,  "Show S&D Lines",          group="Supply & Demand")
i_srcSD      = input.string("OB", "S&D Source", options=["OB", "Swing"], group="Supply & Demand")

// --- Institutional / Bookmap ---
i_volPeriod  = input.int(50,   "Volume Percentile Period", minval=10,       group="Institutional")
i_hvtMult    = input.float(2.5,  "High Vol (Large Lot) Mult", minval=1.0, step=0.1, group="Institutional")
i_showHeat   = input.bool(true,  "Show Bookmap Heatmap",    group="Institutional")

// --- Signals ---
i_showCross  = input.bool(true,  "Show EMA/VWAP Signals",   group="Signals")
i_confirmVol = input.bool(true,  "Confirm with High Vol",   group="Signals")
i_showSweepOb= input.bool(true,  "Show Sweep + OB Signals", group="Signals")

// --- Existing ATR/Targets ---
i_atrPeriod  = input.int(14,   "ATR Period",               minval=1,        group="ATR")
i_atrMult    = input.float(2.0,"ATR Multiplier",           minval=0.1, step=0.1, group="ATR")
i_tp1_rr     = input.float(1.0,  "TP1 RR (Fallback)",     group="Targets", step=0.1)
i_tp2_rr     = input.float(2.0,  "TP2 RR (Fallback)",     group="Targets", step=0.1)
i_targetSnap = input.bool(true,  "Snap targets to MM Layers", group="Targets")

i_showEma9   = input.bool(true,  "Show EMA 9",   group="Moving Averages")
i_showEma20  = input.bool(true,  "Show EMA 20",  group="Moving Averages")
i_showEma50  = input.bool(true,  "Show EMA 50",  group="Moving Averages")
i_showSma200 = input.bool(true,  "Show SMA 200", group="Moving Averages")
i_showVwap   = input.bool(true,  "Show VWAP Bands", group="Moving Averages")

// --- Fair Value Gaps (FVG) ---
i_showFvg    = input.bool(true,  "Show FVGs",               group="Supply & Demand")
i_fvgMinSize = input.float(0.5,  "FVG Min ATR Multiplier",  group="Supply & Demand", step=0.1)

// --- Cumulative Delta ---
i_showCumDelta = input.bool(true, "Show Cumulative Delta Line", group="Institutional")

// --- Market Maker Models (MMXM) ---
i_showMM     = input.bool(true,  "Show MM Blocks (Breaker/Mitigation)", group="Market Maker")
i_eqTolerance = input.float(0.1, "Equal H/L Tolerance %", minval=0.01, step=0.01, group="Market Maker")
i_mmMax      = input.int(3,    "Max MM Blocks", minval=1, maxval=10, group="Market Maker")
i_showDensity= input.bool(true, "Show Density Bubbles", group="Market Maker")

// ═══════════════════════════════════════════════════════════════════════════════
// MOVING AVERAGES
// ═══════════════════════════════════════════════════════════════════════════════
ema9   = ta.ema(close, 9)
ema20  = ta.ema(close, 20)
ema50  = ta.ema(close, 50)
sma200 = ta.sma(close, 200)

plot(i_showEma9   ? ema9   : na, "EMA 9",   color=color.yellow, linewidth=1)
plot(i_showEma20  ? ema20  : na, "EMA 20",  color=color.orange, linewidth=1)
plot(i_showEma50  ? ema50  : na, "EMA 50",  color=color.blue,   linewidth=2)
plot(i_showSma200 ? sma200 : na, "SMA 200", color=color.white,  linewidth=2)

// ═══════════════════════════════════════════════════════════════════════════════
// VWAP WITH ±1σ AND ±2σ BANDS  (manual — resets each session)
// ═══════════════════════════════════════════════════════════════════════════════
var float _cumVP  = 0.0
var float _cumV   = 0.0
var float _cumVP2 = 0.0

bool _newDay = ta.change(time("D")) != 0
if _newDay
    _cumVP  := 0.0
    _cumV   := 0.0
    _cumVP2 := 0.0

_cumVP  += hlc3 * volume
_cumV   += volume
_cumVP2 += hlc3 * hlc3 * volume

vwapVal   = _cumV > 0 ? _cumVP / _cumV : hlc3
_variance = math.max(_cumV > 0 ? _cumVP2 / _cumV - vwapVal * vwapVal : 0.0, 0.0)
_stdev    = math.sqrt(_variance)

vwapU1 = vwapVal + _stdev
vwapL1 = vwapVal - _stdev
vwapU2 = vwapVal + 2.0 * _stdev
vwapL2 = vwapVal - 2.0 * _stdev

plot(i_showVwap ? vwapVal : na, "VWAP",     color=color.teal,                    linewidth=2)
plot(i_showVwap ? vwapU1  : na, "VWAP +1σ", color=color.new(color.teal, 55),     linewidth=1)
plot(i_showVwap ? vwapL1  : na, "VWAP -1σ", color=color.new(color.teal, 55),     linewidth=1)
plot(i_showVwap ? vwapU2  : na, "VWAP +2σ", color=color.new(color.teal, 75),     linewidth=1)
plot(i_showVwap ? vwapL2  : na, "VWAP -2σ", color=color.new(color.teal, 75),     linewidth=1)

// ═══════════════════════════════════════════════════════════════════════════════
// BOOKMAP HEATMAP & LARGE LOT DETECTION (Volume Delta approximation)
// ═══════════════════════════════════════════════════════════════════════════════
volAvg = ta.sma(volume, 50)
volRatio = volume / volAvg
isLargeLot = volRatio >= i_hvtMult

// Heatmap coloring based on volume intensity
color bookmapColor = 
     volRatio > 3.0 ? color.new(color.red,    0) :
     volRatio > 2.0 ? color.new(color.orange, 0) :
     volRatio > 1.5 ? color.new(color.yellow, 0) :
     volRatio > 1.0 ? color.new(color.teal,   0) :
                      color.new(color.gray,   50)

barcolor(i_showHeat ? bookmapColor : na, title="Bookmap Heatmap")

if isLargeLot
    label.new(bar_index, high, "WHALE", color=color.new(color.purple, 0), textcolor=color.white, style=label.style_label_down, size=size.tiny)

// --- Volume Density Engine ---
var float[] volBins = array.new_float(50, 0.0)
var float   binsMin = na
var float   binsMax = na

if _newDay
    array.fill(volBins, 0.0)
    binsMin := low
    binsMax := high

if not na(binsMin) and not na(binsMax)
    float sessionRange = binsMax - binsMin
    if sessionRange > 0
        int binIdx = int((close - binsMin) / sessionRange * 49)
        binIdx := math.max(0, math.min(binIdx, 49))
        array.set(volBins, binIdx, array.get(volBins, binIdx) + volume)

// Draw Density Bubbles at HVNs
if i_showDensity and barstate.islast
    float maxVol = array.max(volBins)
    if maxVol > 0
        for i = 0 to 49
            float bVol = array.get(volBins, i)
            if bVol > maxVol * 0.7 // Top density nodes
                float bPrice = binsMin + (i / 49 * (binsMax - binsMin))
                label.new(bar_index + 2, bPrice, "●", color=color.new(color.white, 100), textcolor=color.new(color.teal, 40), size=size.normal)

// ═══════════════════════════════════════════════════════════════════════════════
// ATR
// ═══════════════════════════════════════════════════════════════════════════════
atrVal = ta.atr(i_atrPeriod)

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIRMED SWINGS  (pivothigh/low confirmed i_swingLB bars after formation)
// ═══════════════════════════════════════════════════════════════════════════════
swingH = ta.pivothigh(high, i_swingLB, i_swingLB)  // confirmed swing high
swingL = ta.pivotlow(low,   i_swingLB, i_swingLB)  // confirmed swing low

// ═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEP DETECTION
// ═══════════════════════════════════════════════════════════════════════════════
var float lastSH = na
var float lastSL = na

// MM Engineered Liquidity (EQH / EQL)
var float prevSH = na
var float prevSL = na
var line[] eqhLines = array.new_line()
var line[] eqlLines = array.new_line()
bool isEQH = false
bool isEQL = false

if not na(swingH)
    if not na(prevSH)
        diff = math.abs(swingH - prevSH) / prevSH * 100
        if diff <= i_eqTolerance
            isEQH := true
            if array.size(eqhLines) >= 5
                line.delete(array.shift(eqhLines))
            array.push(eqhLines, line.new(bar_index - i_swingLB, swingH, bar_index + 10, swingH, color=color.new(color.red, 30), width=1, style=line.style_dotted, extend=extend.right))
    prevSH := swingH

if not na(swingL)
    if not na(prevSL)
        diff = math.abs(swingL - prevSL) / prevSL * 100
        if diff <= i_eqTolerance
            isEQL := true
            if array.size(eqlLines) >= 5
                line.delete(array.shift(eqlLines))
            array.push(eqlLines, line.new(bar_index - i_swingLB, swingL, bar_index + 10, swingL, color=color.new(color.green, 30), width=1, style=line.style_dotted, extend=extend.right))
    prevSL := swingL

// Clean EQH/EQL lines once swept
if array.size(eqhLines) > 0
    for i = array.size(eqhLines)-1 to 0
        l = array.get(eqhLines, i)
        if high > line.get_y1(l)
            line.delete(l)
            array.remove(eqhLines, i)
        else
            line.set_x2(l, bar_index + 10)

if array.size(eqlLines) > 0
    for i = array.size(eqlLines)-1 to 0
        l = array.get(eqlLines, i)
        if low < line.get_y1(l)
            line.delete(l)
            array.remove(eqlLines, i)
        else
            line.set_x2(l, bar_index + 10)

if not na(swingH)
    lastSH := swingH
if not na(swingL)
    lastSL := swingL

// Wick pierces swing level, close returns inside — no future bar access
bearSweep = not na(lastSH) and high > lastSH and close < lastSH
bullSweep = not na(lastSL) and low  < lastSL and close > lastSL

plotshape(bearSweep, "Bear Sweep", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,   0), size=size.small)
plotshape(bullSweep, "Bull Sweep", style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0), size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// ORDER BLOCKS
// ═══════════════════════════════════════════════════════════════════════════════
// Impulse detected on current (closed) bar vs close i_obLookback bars ago
bullImpulse = close > close[i_obLookback] + atrVal * i_atrMult
bearImpulse = close < close[i_obLookback] - atrVal * i_atrMult

// Return index (1..lookback) of most recent bearish candle — becomes bullish OB
f_lastBearCandle() =>
    int result = -1
    for i = 1 to i_obLookback
        if close[i] < open[i]
            result := i
            break
    result

// Return index of most recent bullish candle — becomes bearish OB
f_lastBullCandle() =>
    int result = -1
    for i = 1 to i_obLookback
        if close[i] >= open[i]
            result := i
            break
    result

// Compute indices once per bar (avoid redundant calls)
int bullObIdx = bullImpulse ? f_lastBearCandle() : -1
int bearObIdx = bearImpulse ? f_lastBullCandle() : -1

var box[] bullOB        = array.new_box()
var box[] bearOB        = array.new_box()
var int   lastBullObBar = na
var int   lastBearObBar = na

// MM Blocks (Breakers & Mitigations)
var line[] bullMM = array.new_line()
var line[] bearMM = array.new_line()

if bullObIdx > 0
    int absBar = bar_index - bullObIdx
    if na(lastBullObBar) or absBar != lastBullObBar
        lastBullObBar := absBar
        if array.size(bullOB) >= i_obMax
            box.delete(array.shift(bullOB))
        array.push(bullOB, box.new(
             bar_index - bullObIdx, high[bullObIdx],
             bar_index + 20,        low[bullObIdx],
             border_color = color.new(color.green, 0),
             bgcolor      = color.new(color.green, 82),
             border_width = 1))

if bearObIdx > 0
    int absBar = bar_index - bearObIdx
    if na(lastBearObBar) or absBar != lastBearObBar
        lastBearObBar := absBar
        if array.size(bearOB) >= i_obMax
            box.delete(array.shift(bearOB))
        array.push(bearOB, box.new(
             bar_index - bearObIdx, high[bearObIdx],
             bar_index + 20,        low[bearObIdx],
             border_color = color.new(color.red, 0),
             bgcolor      = color.new(color.red, 82),
             border_width = 1))

// Extend active OBs rightward and check for touches / invalidation
bool bullObTouched = false
bool bearObTouched = false

if array.size(bullOB) > 0
    int _bi = array.size(bullOB) - 1
    while _bi >= 0
        b       = array.get(bullOB, _bi)
        obTop   = box.get_top(b)
        obBot   = box.get_bottom(b)
        box.set_right(b, bar_index + 20)
        if low <= obTop and low >= obBot
            bullObTouched := true
        if close < obBot
            // OB Broken -> check for Breaker vs Mitigation
            if i_showMM
                bool isBreaker = false
                // Check if a sweep happened within the last 15 bars
                for j = 0 to 15
                    if bullSweep[j]
                        isBreaker := true
                        break
                
                if array.size(bullMM) >= i_mmMax
                    line.delete(array.shift(bullMM))
                
                color mmCol = isBreaker ? color.new(color.orange, 0) : color.new(color.gray, 30)
                int mmWidth = isBreaker ? 2 : 1
                array.push(bullMM, line.new(bar_index, obBot, bar_index + 20, obBot, color=mmCol, width=mmWidth, style=line.style_solid, extend=extend.right))
                label.new(bar_index, obBot, isBreaker ? "BREAKER" : "MITIGATION", color=color.new(mmCol, 50), textcolor=color.white, style=label.style_label_up, size=size.tiny)

            box.delete(b)
            array.remove(bullOB, _bi)
        _bi -= 1

if array.size(bearOB) > 0
    int _bi = array.size(bearOB) - 1
    while _bi >= 0
        b       = array.get(bearOB, _bi)
        obTop   = box.get_top(b)
        obBot   = box.get_bottom(b)
        box.set_right(b, bar_index + 20)
        if high >= obBot and high <= obTop
            bearObTouched := true
        if close > obTop
            // OB Broken -> check for Breaker vs Mitigation
            if i_showMM
                bool isBreaker = false
                for j = 0 to 15
                    if bearSweep[j]
                        isBreaker := true
                        break
                
                if array.size(bearMM) >= i_mmMax
                    line.delete(array.shift(bearMM))
                
                color mmCol = isBreaker ? color.new(color.orange, 0) : color.new(color.gray, 30)
                int mmWidth = isBreaker ? 2 : 1
                array.push(bearMM, line.new(bar_index, obTop, bar_index + 20, obTop, color=mmCol, width=mmWidth, style=line.style_solid, extend=extend.right))
                label.new(bar_index, obTop, isBreaker ? "BREAKER" : "MITIGATION", color=color.new(mmCol, 50), textcolor=color.white, style=label.style_label_down, size=size.tiny)

            box.delete(b)
            array.remove(bearOB, _bi)
        _bi -= 1

// ═══════════════════════════════════════════════════════════════════════════════
// UNMITIGATED S&D LINES
// ═══════════════════════════════════════════════════════════════════════════════
var line bullSdLine = na
var line bearSdLine = na

if i_showSD
    if array.size(bullOB) > 0
        bBull = array.get(bullOB, array.size(bullOB)-1)
        top   = box.get_top(bBull)
        if na(bullSdLine)
            bullSdLine := line.new(bar_index, top, bar_index + 10, top, color=color.new(color.green, 20), style=line.style_solid, width=2, extend=extend.right)
        else
            line.set_xy1(bullSdLine, bar_index, top)
            line.set_xy2(bullSdLine, bar_index + 10, top)
    else
        line.delete(bullSdLine)
        bullSdLine := na
    
    if array.size(bearOB) > 0
        bBear = array.get(bearOB, array.size(bearOB)-1)
        bot   = box.get_bottom(bBear)
        if na(bearSdLine)
            bearSdLine := line.new(bar_index, bot, bar_index + 10, bot, color=color.new(color.red, 20), style=line.style_solid, width=2, extend=extend.right)
        else
            line.set_xy1(bearSdLine, bar_index, bot)
            line.set_xy2(bearSdLine, bar_index + 10, bot)
    else
        line.delete(bearSdLine)
        bearSdLine := na

// ═══════════════════════════════════════════════════════════════════════════════
// FAIR VALUE GAPS (FVG / IMBALANCE)
// ═══════════════════════════════════════════════════════════════════════════════
var box[] bullFVG = array.new_box()
var box[] bearFVG = array.new_box()

isBullFVG = low > high[2] and (low - high[2] > atrVal * i_fvgMinSize)
isBearFVG = high < low[2] and (low[2] - high > atrVal * i_fvgMinSize)

if i_showFvg
    if isBullFVG
        array.push(bullFVG, box.new(bar_index[2], low, bar_index, high[2], bgcolor=color.new(color.green, 90), border_color=na))
    if isBearFVG
        array.push(bearFVG, box.new(bar_index[2], low[2], bar_index, high, bgcolor=color.new(color.red, 90), border_color=na))

// Clean mitigated FVGs
if array.size(bullFVG) > 0
    for i = array.size(bullFVG)-1 to 0
        b = array.get(bullFVG, i)
        if low < box.get_bottom(b)
            box.delete(b)
            array.remove(bullFVG, i)
        else
            box.set_right(b, bar_index + 2)

if array.size(bearFVG) > 0
    for i = array.size(bearFVG)-1 to 0
        b = array.get(bearFVG, i)
        if high > box.get_top(b)
            box.delete(b)
            array.remove(bearFVG, i)
        else
            box.set_right(b, bar_index + 2)

// ═══════════════════════════════════════════════════════════════════════════════
// MARKET STRUCTURE — BOS & CHoCH
// ═══════════════════════════════════════════════════════════════════════════════
var float msLastSH  = na   // most recent confirmed swing high
var float msLastSL  = na   // most recent confirmed swing low
var bool  inUptrend = false // uptrend flag (higher highs)
var line[] msLines  = array.new_line()

bool bearBOS  = false
bool chochSig = false

if not na(swingH)
    // CHoCH: new swing high is LOWER than previous while uptrend was in force
    if not na(msLastSH) and swingH < msLastSH and inUptrend
        chochSig  := true
        inUptrend := false
    // Higher high resets uptrend flag
    if not na(msLastSH) and swingH > msLastSH
        inUptrend := true
    msLastSH := swingH

if not na(swingL)
    msLastSL := swingL

// BOS: close crosses swing low (Bearish) or swing high (Bullish)
if not na(msLastSL)
    bearBOS := close < msLastSL and close[1] >= msLastSL
bool bullBOS = false
if not na(msLastSH)
    bullBOS := close > msLastSH and close[1] <= msLastSH

if bearBOS
    if array.size(msLines) >= 30
        line.delete(array.shift(msLines))
    array.push(msLines,
         line.new(bar_index - i_swingLB, msLastSL, bar_index + 10, msLastSL,
              color=color.red, style=line.style_dashed, width=1))

if bullBOS
    if array.size(msLines) >= 30
        line.delete(array.shift(msLines))
    array.push(msLines,
         line.new(bar_index - i_swingLB, msLastSH, bar_index + 10, msLastSH,
              color=color.green, style=line.style_dashed, width=1))

if chochSig
    if array.size(msLines) >= 30
        line.delete(array.shift(msLines))
    array.push(msLines,
         line.new(bar_index - i_swingLB, msLastSH, bar_index + 10, msLastSH,
              color=color.orange, style=line.style_solid, width=2))

// ═══════════════════════════════════════════════════════════════════════════════
// SUPPORT & RESISTANCE  (last 3 swing highs → resistance, last 3 lows → support)
// ═══════════════════════════════════════════════════════════════════════════════
var line[]  resLines = array.new_line()
var float[] resLvls  = array.new_float()
var line[]  supLines = array.new_line()
var float[] supLvls  = array.new_float()

if not na(swingH)
    if array.size(resLvls) >= 3
        line.delete(array.shift(resLines))
        array.shift(resLvls)
    array.push(resLvls, swingH)
    array.push(resLines,
         line.new(bar_index - i_swingLB, swingH, bar_index, swingH,
              color=color.new(color.red, 35), width=1, extend=extend.right))

if not na(swingL)
    if array.size(supLvls) >= 3
        line.delete(array.shift(supLines))
        array.shift(supLvls)
    array.push(supLvls, swingL)
    array.push(supLines,
         line.new(bar_index - i_swingLB, swingL, bar_index, swingL,
              color=color.new(color.green, 35), width=1, extend=extend.right))

// Prune broken resistance levels (close above)
int resSz = array.size(resLvls)
if resSz > 0
    int _ri = resSz - 1
    while _ri >= 0
        if close > array.get(resLvls, _ri)
            line.delete(array.remove(resLines, _ri))
            array.remove(resLvls, _ri)
        _ri -= 1

// Prune broken support levels (close below)
int supSz = array.size(supLvls)
if supSz > 0
    int _si = supSz - 1
    while _si >= 0
        if close < array.get(supLvls, _si)
            line.delete(array.remove(supLines, _si))
            array.remove(supLvls, _si)
        _si -= 1

// ═══════════════════════════════════════════════════════════════════════════════
// EMA / VWAP CROSSOVER SIGNALS
// ═══════════════════════════════════════════════════════════════════════════════
emaCrossUp = ta.crossover(ema9, ema20)
emaCrossDn = ta.crossunder(ema9, ema20)

// Institutional Filter: Buy only above VWAP in uptrend, Sell below VWAP in downtrend
// Or as requested, unified with high volume
// Refined Filter: EMA crossover MUST occur with structural confirmation (BOS/CHoCH) and high volume
var int lastStructureBar = -100
if bearBOS or chochSig // Simplified structure check
    lastStructureBar := bar_index

float volRankPct = ta.percentrank(volume, i_volPeriod)
bool highVolConfirm = volRankPct >= 95.0

structureConfirm = (bar_index - lastStructureBar <= 10)

buySignal  = i_showCross and emaCrossUp and structureConfirm and highVolConfirm and close > vwapVal
sellSignal = i_showCross and emaCrossDn and structureConfirm and highVolConfirm and close < vwapVal

plotshape(buySignal,  "Buy Signal",  style=shape.labelup,   location=location.belowbar, color=color.new(color.blue, 0),  size=size.small, text="BUY",  textcolor=color.white)
plotshape(sellSignal, "Sell Signal", style=shape.labeldown, location=location.abovebar, color=color.new(color.maroon, 0), size=size.small, text="SELL", textcolor=color.white)

// ═══════════════════════════════════════════════════════════════════════════════
// REAL ORDERS TRACKING (Session Delta)
// ═══════════════════════════════════════════════════════════════════════════════
var float sessionBuyVol  = 0.0
var float sessionSellVol = 0.0

if _newDay
    sessionBuyVol  := 0.0
    sessionSellVol := 0.0

sessionBuyVol  += (close >= open ? volume : 0.0)
sessionSellVol += (close <  open ? volume : 0.0)
sessionDelta    = sessionBuyVol - sessionSellVol
sessionDeltaPct = (sessionBuyVol + sessionSellVol) > 0 ? (sessionDelta / (sessionBuyVol + sessionSellVol) * 100) : 0.0

// ═══════════════════════════════════════════════════════════════════════════════
// CUMULATIVE DELTA LINE (Scaled for overlay)
// ═══════════════════════════════════════════════════════════════════════════════
// We scale the delta percentage to fit between VWAP bands for visual context
deltaPlotLine = vwapVal + (sessionDeltaPct / 100 * (vwapU1 - vwapVal))
plot(i_showCumDelta ? deltaPlotLine : na, "Cum Delta Plot", color=color.new(color.yellow, 30), linewidth=1, style=plot.style_linebr)

// ═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEP + OB (A+ SETUP)
// ═══════════════════════════════════════════════════════════════════════════════
var int lastSweepBar = -100
if bullSweep or bearSweep
    lastSweepBar := bar_index

// A+ Bullish: Sweep happened within last 5 bars AND we are in a Bullish OB
aPlusBull = i_showSweepOb and (bar_index - lastSweepBar <= 5) and bullObTouched and bullSweep[bar_index - lastSweepBar]
aPlusBear = i_showSweepOb and (bar_index - lastSweepBar <= 5) and bearObTouched and bearSweep[bar_index - lastSweepBar]

plotchar(aPlusBull, "A+ Bull Setup", char='★', location=location.belowbar, color=color.new(color.yellow, 0), size=size.normal, text="A+ BUY", textcolor=color.black)
plotchar(aPlusBear, "A+ Bear Setup", char='★', location=location.abovebar, color=color.new(color.yellow, 0), size=size.normal, text="A+ SELL", textcolor=color.black)

// ═══════════════════════════════════════════════════════════════════════════════
// SMART MONEY REVERSAL (SMR) - MMXM
// ═══════════════════════════════════════════════════════════════════════════════
// SMR is early confirmation of a Market Maker Buy/Sell Model reversal
bool smrBuy  = bullSweep and close > high[1] // Sweep then aggressive close above
bool smrSell = bearSweep and close < low[1]   // Sweep then aggressive close below

plotshape(i_showMM and smrBuy,  "SMR Buy",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="SMR (MMBM)",  textcolor=color.white)
plotshape(i_showMM and smrSell, "SMR Sell", style=shape.triangledown, location=location.abovebar, color=color.new(color.fuchsia, 0), size=size.small, text="SMR (MMSM)", textcolor=color.white)

// ═══════════════════════════════════════════════════════════════════════════════
// INSTITUTIONAL LEVELS
// Condition: volume in top 5th percentile AND candle qualifies as order block
// ═══════════════════════════════════════════════════════════════════════════════
float volRank = ta.percentrank(volume, i_volPeriod) // 0–100; ≥95 = top 5%
bool  highVol = volRank >= 95.0

// Bullish institutional: high vol + bullish impulse + prior bearish candle (OB) found
bool instBuy  = highVol and bullObIdx > 0
bool instSell = highVol and bearObIdx > 0

var int lastInstBuyBar  = na
var int lastInstSellBar = na

if instBuy
    int absBar = bar_index - bullObIdx
    if na(lastInstBuyBar) or absBar != lastInstBuyBar
        lastInstBuyBar := absBar
        label.new(bar_index - bullObIdx, low[bullObIdx], "INST BUY ▲",
             color=color.green, textcolor=color.white,
             style=label.style_label_up, size=size.small)
        line.new(bar_index - bullObIdx, low[bullObIdx], bar_index + 30, low[bullObIdx],
             color=color.new(color.green, 0), width=2)
             
        // Project SL and TP visually
        float entryP = close
        float sl1 = low[bullObIdx]
        float sl2 = not na(lastSL) ? lastSL : sl1 - atrVal
        float risk = entryP - sl1 > 0 ? entryP - sl1 : atrVal

        line.new(bar_index, sl1, bar_index + 20, sl1, color=color.new(color.red, 30), style=line.style_dashed, width=1)
        label.new(bar_index + 20, sl1, "SL1", color=color.new(color.red, 30), textcolor=color.white, style=label.style_label_left, size=size.tiny)
        line.new(bar_index, sl2, bar_index + 20, sl2, color=color.new(color.maroon, 20), style=line.style_dotted, width=1)
        label.new(bar_index + 20, sl2, "SL2", color=color.new(color.maroon, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)

        // Target Snapping Logic
        float targetTP1 = entryP + risk * i_tp1_rr
        float targetTP2 = entryP + risk * i_tp2_rr
        
        if i_targetSnap
            // Scan for nearest MM Line or HVN above entry
            float closestHVN = na
            float maxDen = array.max(volBins)
            for i = 0 to 49
                if array.get(volBins, i) > maxDen * 0.7
                    float p = binsMin + (i / 49 * (binsMax - binsMin))
                    if p > entryP and (na(closestHVN) or p < closestHVN)
                        closestHVN := p
            
            if not na(closestHVN)
                targetTP1 := closestHVN
            
            // TP2 targets next major MM line (simulated here by 2x HVN step or POC)
            targetTP2 := math.max(targetTP2, targetTP1 + risk)

        line.new(bar_index, targetTP1, bar_index + 20, targetTP1, color=color.new(color.green, 30), style=line.style_dashed, width=1)
        label.new(bar_index + 20, targetTP1, "TP1 (LVL)", color=color.new(color.green, 0), textcolor=color.white, style=label.style_label_left, size=size.tiny)
        line.new(bar_index, targetTP2, bar_index + 20, targetTP2, color=color.new(color.green, 30), style=line.style_dashed, width=1)
        label.new(bar_index + 20, targetTP2, "TP2 (ZONE)", color=color.new(color.green, 0), textcolor=color.white, style=label.style_label_left, size=size.tiny)

if instSell
    int absBar = bar_index - bearObIdx
    if na(lastInstSellBar) or absBar != lastInstSellBar
        lastInstSellBar := absBar
        label.new(bar_index - bearObIdx, high[bearObIdx], "INST SELL ▼",
             color=color.red, textcolor=color.white,
             style=label.style_label_down, size=size.small)
        line.new(bar_index - bearObIdx, high[bearObIdx], bar_index + 30, high[bearObIdx],
             color=color.new(color.red, 0), width=2)
             
        // Project SL and TP visually
        float entryP = close
        float sl1 = high[bearObIdx]
        float sl2 = not na(lastSH) ? lastSH : sl1 + atrVal
        float risk = sl1 - entryP > 0 ? sl1 - entryP : atrVal

        line.new(bar_index, sl1, bar_index + 20, sl1, color=color.new(color.red, 30), style=line.style_dashed, width=1)
        label.new(bar_index + 20, sl1, "SL1", color=color.new(color.red, 30), textcolor=color.white, style=label.style_label_left, size=size.tiny)
        line.new(bar_index, sl2, bar_index + 20, sl2, color=color.new(color.maroon, 20), style=line.style_dotted, width=1)
        label.new(bar_index + 20, sl2, "SL2", color=color.new(color.maroon, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)

        // Target Snapping Logic
        float targetTP1 = entryP - risk * i_tp1_rr
        float targetTP2 = entryP - risk * i_tp2_rr

        if i_targetSnap
            float closestHVN = na
            float maxDen = array.max(volBins)
            for i = 0 to 49
                if array.get(volBins, i) > maxDen * 0.7
                    float p = binsMin + (i / 49 * (binsMax - binsMin))
                    if p < entryP and (na(closestHVN) or p > closestHVN)
                        closestHVN := p
            
            if not na(closestHVN)
                targetTP1 := closestHVN
            
            targetTP2 := math.min(targetTP2, targetTP1 - risk)

        line.new(bar_index, targetTP1, bar_index + 20, targetTP1, color=color.new(color.green, 30), style=line.style_dashed, width=1)
        label.new(bar_index + 20, targetTP1, "TP1 (LVL)", color=color.new(color.green, 0), textcolor=color.white, style=label.style_label_left, size=size.tiny)
        line.new(bar_index, targetTP2, bar_index + 20, targetTP2, color=color.new(color.green, 30), style=line.style_dashed, width=1)
        label.new(bar_index + 20, targetTP2, "TP2 (ZONE)", color=color.new(color.green, 0), textcolor=color.white, style=label.style_label_left, size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════════
alertcondition(bullSweep,    "Bullish Liquidity Sweep",  "Bull sweep: wick pierced swing low, closed above")
alertcondition(bearSweep,    "Bearish Liquidity Sweep",  "Bear sweep: wick pierced swing high, closed below")
alertcondition(bullObTouched,"Bullish OB Touch",         "Price entered bullish order block zone")
alertcondition(bearObTouched,"Bearish OB Touch",         "Price entered bearish order block zone")
alertcondition(bearBOS,      "Bearish BOS",              "Bearish break of structure: close < swing low")
alertcondition(chochSig,     "CHoCH",                    "Change of character: lower high confirmed")
alertcondition(instBuy,      "Institutional Buy",        "High-vol bullish OB impulse detected")
alertcondition(instSell,     "Institutional Sell",       "High-vol bearish OB impulse detected")
alertcondition(buySignal,    "EMA/VWAP Buy Signal",      "EMA 9/20 cross + VWAP filter Buy")
alertcondition(sellSignal,   "EMA/VWAP Sell Signal",     "EMA 9/20 cross + VWAP filter Sell")
alertcondition(aPlusBull,    "A+ Bullish Setup",         "Sweep + OB Touch Bullish")
alertcondition(aPlusBear,    "A+ Bearish Setup",         "Sweep + OB Touch Bearish")

// ═══════════════════════════════════════════════════════════════════════════════
// REAL ORDERS TRACKING (Session Delta Table)
// ═══════════════════════════════════════════════════════════════════════════════
var table deltaTable = table.new(position.bottom_right, 2, 2, bgcolor=color.new(color.black, 50), border_width=1, border_color=color.gray)
if barstate.islast
    color deltaCol = sessionDelta >= 0 ? color.green : color.red
    table.cell(deltaTable, 0, 0, "Session Delta", text_color=color.white, text_size=size.small)
    table.cell(deltaTable, 1, 0, str.tostring(sessionDelta, "#.##"), text_color=deltaCol, text_size=size.small)
    table.cell(deltaTable, 0, 1, "Delta %", text_color=color.white, text_size=size.small)
    table.cell(deltaTable, 1, 1, str.tostring(sessionDeltaPct, "#.##") + "%", text_color=deltaCol, text_size=size.small)

